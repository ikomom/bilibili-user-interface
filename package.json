{
  "name": "fastapi-full-stack-template",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "bun run --filter frontend dev",
    "dev:backend": "cd backend && uv run fastapi dev app/main.py --port 8888",
    "dev:all": "concurrently \"bun run dev:backend\" \"bun run dev\"",
    "lint": "bun run --filter frontend lint",
    "lint:backend": "cd backend && bash ./scripts/lint.sh",
    "format:backend": "cd backend && bash ./scripts/format.sh",
    "test": "bun run --filter frontend test",
    "test:ui": "bun run --filter frontend test:ui",
    "test:backend": "cd backend && bash ./scripts/test.sh"
  }
}
